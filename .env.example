# ─── WLED matrix (used by clawd.py / clawd_daemon.py) ─────────────────
# Required for the Clawd mascot animations.
WLED_URL=http://wled.local
WLED_WIDTH=16
WLED_HEIGHT=16
# Flip the sprite horizontally/vertically if your matrix is wired such
# that Clawd appears mirrored compared to the demo GIF. Leave blank
# (or set to false) if he already looks correct.
WLED_MIRROR_X=false
WLED_MIRROR_Y=false

# ─── Home Assistant (used by flash.sh / flash_stop.sh) ────────────────
# Optional — skip these lines if you don't want the smart-light flashes.
HA_URL=https://your-home-assistant-host
HA_TOKEN=your_long_lived_access_token_here
HA_ENTITY=light.your_light_entity_id
